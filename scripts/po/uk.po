msgstr "файли, передані як аргументи, повинні існувати"

#: scripts/dpkg-name.pl
#, perl-format
msgid "Usage: %s [<option>...] <file>...\n"
msgstr "Використання: %s [<параметр>...] <файл>...\n"

#: scripts/dpkg-name.pl
msgid ""
"\n"
"Options:\n"
"  -a, --no-architecture    no architecture part in filename.\n"
"  -o, --overwrite          overwrite if file exists.\n"
"  -k, --symlink            do not create a new file, but a symlink.\n"
"  -s, --subdir [dir]       move file into subdirectory (use with care).\n"
"  -c, --create-dir         create target directory if not there (use with "
"care).\n"
"  -?, --help               show this help message.\n"
"  -v, --version            show the version.\n"
"\n"
"file.deb changes to <package>_<version>_<architecture>.<package_type>\n"
"according to the 'underscores convention'.\n"
msgstr ""
"\n"
"Параметри:\n"
"  -a, --no-architecture    без частини архітектури в назві файлу.\n"
"  -o, --overwrite          перезаписати, якщо файл існує.\n"
"  -k, --symlink            не створювати новий файл, а створити\n"
"                                        символічне посилання.\n"
"  -s, --subdir [каталог]   перемістити файл у підкаталог\n"
"                                        (використовувати обережно).\n"
"  -c, --create-dir         створити цільовий каталог, якщо\n"
"                                        його немає (використовувати "
"обережно).\n"
"  -?, --help               показати це довідкове повідомлення.\n"
"  -v, --version            показати версію.\n"
"\n"
"file.deb перетворюється на <пакунок>_<версія>_<архітектура>.<тип_пакунка>\n"
"згідно з 'домовленістю про підкреслення'.\n"


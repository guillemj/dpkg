msgstr "не вдалося встановити вихідний файл buildinfo '%s'"

#: scripts/dpkg-genchanges.pl
msgid ""
"Options:\n"
"  --build=<type>[,...]     specify the build <type>: full, source, binary,\n"
"                             any, all (default is 'full').\n"
"  -g                       source and arch-indep build.\n"
"  -G                       source and arch-specific build.\n"
"  -b                       binary-only, no source files.\n"
"  -B                       binary-only, only arch-specific files.\n"
"  -A                       binary-only, only arch-indep files.\n"
"  -S                       source-only, no binary files.\n"
"  -c<control-file>         get control info from this file.\n"
"  -l<changelog-file>       get per-version info from this file.\n"
"  -f<files-list-file>      get .deb files list from this file.\n"
"  -v<since-version>        include all changes later than version.\n"
"  -C<changes-description>  use change description from this file.\n"
"  -m<maintainer>           override control's maintainer value.\n"
"  -e<maintainer>           override changelog's maintainer value.\n"
"  -u<upload-files-dir>     directory with files (default is '..').\n"
"  -si                      source includes orig, if new upstream (default).\n"
"  -sa                      source includes orig, always.\n"
"  -sd                      source is diff and .dsc only.\n"
"  -q                       quiet - no informational messages on stderr.\n"
"  -F<changelog-format>     force changelog format.\n"
"  -V<name>=<value>         set a substitution variable.\n"
"  -T<substvars-file>       read variables here, not debian/substvars.\n"
"  -D<field>=<value>        override or add a field and value.\n"
"  -U<field>                remove a field.\n"
"  -O[<filename>]           write to stdout (default) or <filename>.\n"
"  -?, --help               show this help message.\n"
"      --version            show the version.\n"
msgstr ""
"Параметри:\n"
"  --build=<тип>[,...]      вказати тип збірки <тип>: full, source, binary,\n"
"                                        any, all (типово 'full').\n"
"  -g                       вихідний пакунок та файли, незалежні від "
"архітектури.\n"
"  -G                       вихідний пакунок та файли, специфічні для "
"архітектури.\n"
"  -b                       лише бінарні файли, без вихідних.\n"
"  -B                       лише бінарні файли, лише специфічні для "
"архітектури.\n"
"  -A                       лише бінарні файли, лише незалежні від "
"архітектури.\n"
"  -S                       лише вихідний пакунок, без бінарних файлів.\n"
"  -c<файл-керування>       отримати інформацію керування з цього файлу.\n"
"  -l<файл-журналу-змін>    отримати інформацію про версії з цього файлу.\n"
"  -f<файл-списку-файлів>   отримати список файлів .deb з цього файлу.\n"
"  -v<версія>               включити всі зміни, новіші за <версія>.\n"
"  -C<опис-змін>            використовувати опис змін з цього файлу.\n"
"  -m<супровідник>          перевизначити значення супровідника з control.\n"
"  -e<супровідник>          перевизначити значення супровідника з changelog.\n"
"  -u<каталог-файлів>       каталог із файлами (типово '..').\n"
"  -si                      вихідний пакунок містить orig, якщо новий "
"upstream (типово).\n"
"  -sa                      вихідний пакунок завжди містить orig.\n"
"  -sd                      вихідний пакунок містить лише diff та .dsc.\n"
"  -q                       тихий режим - без інформаційних повідомлень на "
"stderr.\n"
"  -F<формат-журналу-змін>  примусово встановити формат журналу змін.\n"
"  -V<назва>=<значення>     встановити змінну підстановки.\n"
"  -T<файл-змін>            читати змінні тут, а не з debian/substvars.\n"
"  -D<поле>=<значення>      перевизначити або додати поле та значення.\n"
"  -U<поле>                 видалити поле.\n"
"  -O[<файл>]               записувати на stdout (типово) або до <файл>.\n"
"  -?, --help               показати це довідкове повідомлення.\n"
"  --version                показати версію.\n"


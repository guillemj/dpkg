msgstr "не приймає аргументів, що не є параметрами"

#: scripts/dpkg-scanpackages.pl
#, perl-format
msgid ""
"Usage: %s [<option>...] <binary-path> [<override-file> [<path-prefix>]] > "
"Packages\n"
"\n"
"Options:\n"
"  -t, --type <type>        scan for <type> packages (default is 'deb').\n"
"  -a, --arch <arch>        architecture to scan for (with implicit arch "
"all).\n"
"      --no-implicit-arch   do not add implicit architecture all to --arch.\n"
"  -h, --hash <hash-list>   only generate hashes for the specified list.\n"
"  -m, --multiversion       allow multiple versions of a single package.\n"
"  -e, --extra-override <file>\n"
"                           use extra override file.\n"
"  -M, --medium <medium>    add X-Medium field for dselect media access "
"method\n"
"  -?, --help               show this help message.\n"
"      --version            show the version.\n"
msgstr ""
"Використання: %s [<параметр>...] <шлях-до-бінарного-файлу> [<файл-"
"перевизначення> [<префікс-шляху>]] > Packages\n"
"\n"
"Параметри:\n"
"  -t, --type <тип>         сканувати пакунки типу <тип> (типово 'deb').\n"
"  -a, --arch <арх>         архітектура для сканування (з неявним arch all).\n"
"      --no-implicit-arch   не додавати неявну архітектуру all до --arch.\n"
"  -h, --hash <список-хешів>генерувати хеші лише для вказаного списку.\n"
"  -m, --multiversion       дозволити кілька версій одного пакунка.\n"
"  -e, --extra-override <файл>\n"
"                           використовувати додатковий файл перевизначення.\n"
"  -M, --medium <носій>     додати поле X-Medium для методу доступу\n"
"                                        до носія у dselect\n"
"  -?, --help               показати це довідкове повідомлення.\n"
"  --version                показати версію.\n"


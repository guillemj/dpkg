#: scripts/dpkg-parsechangelog.pl
msgid ""
"Options:\n"
"  -l, --file <changelog-file>\n"
"                           get per-version info from this file.\n"
"  -F <changelog-format>    force changelog format.\n"
"  -S, --show-field <field> show the values for <field>.\n"
"  -?, --help               show this help message.\n"
"      --version            show the version."
msgstr ""
"Параметри:\n"
"  -l, --file <файл-журналу-змін>\n"
"                           отримати інформацію для кожної версії з цього "
"файлу.\n"
"  -F <формат-журналу-змін> примусово встановити\n"
"                                        формат журналу змін.\n"
"  -S, --show-field <поле>  показати значення для <поле>.\n"
"  -?, --help               показати це довідкове повідомлення.\n"
"  --version                показати версію."

#: scripts/dpkg-parsechangelog.pl
msgid ""
"Parser options:\n"
"      --format <output-format>\n"
"                           set output format (defaults to 'dpkg').\n"
"      --reverse            include all changes in reverse order.\n"
"      --all                include all changes.\n"
"  -s, --since <version>    include all changes later than <version>.\n"
"  -v <version>             ditto.\n"
"  -u, --until <version>    include all changes earlier than <version>.\n"
"  -f, --from <version>     include all changes equal or later than "
"<version>.\n"
"  -t, --to <version>       include all changes up to or equal than "
"<version>.\n"
"  -c, --count <number>     include <number> entries from the top (or tail\n"
"                             if <number> is lower than 0).\n"
"  -n <number>              ditto.\n"
"  -o, --offset <number>    change starting point for --count, counted from\n"
"                             the top (or tail if <number> is lower than 0).\n"
msgstr ""
"Параметри парсера:\n"
"      --format <формат виводу>\n"
"                           встановити формат виводу (типово 'dpkg').\n"
"      --reverse            включити всі зміни у зворотному порядку.\n"
"      --all                включити всі зміни.\n"
"  -s, --since <версія>     включити всі зміни, пізніші за <версія>.\n"
"  -v <версія>              те саме.\n"
"  -u, --until <версія>     включити всі зміни, раніші за <версія>.\n"
"  -f, --from <версія>      включити всі зміни, рівні або пізніші за "
"<версія>.\n"
"  -t, --to <версія>        включити всі зміни, рівні або раніші за "
"<версія>.\n"
"  -c, --count <число>      включити <число> записів з початку\n"
"                                        (або з кінця якщо <число> менше за "
"0).\n"
"  -n <число>               те саме.\n"
"  -o, --offset <число>     змінити початкову точку для --count,\n"
"                                        відраховуючи з початку (або з "
"кінця,\n"
"                                        якщо <число> менше за 0).\n"

#: scripts/dpkg-parsechangelog.pl

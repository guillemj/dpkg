msgstr "приймати метадані quilt <версія>, навіть якщо вони невідомі"

#: scripts/Dpkg/Source/Package/V3/Quilt.pm
#, perl-format
msgid "cannot create symlink %s"
msgstr "не вдалося створити символічне посилання %s"

#: scripts/Dpkg/Source/Package/V3/Quilt.pm
#, perl-format
msgid "using patch list from %s"
msgstr "використовую список патчів від %s"

#: scripts/Dpkg/Source/Package/V3/Quilt.pm
#, perl-format
msgid "unsupported version of the quilt metadata: %s"
msgstr "непідтримувана версія метаданих quilt: %s"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "file %s has no final newline (either original or modified version)"
msgstr ""
"файл %s не має кінцевого символу перенесення рядка (ні оригінальна, ні "
"змінена версія)"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "unknown line from diff -u on %s: '%s'"
msgstr "невідомий рядок з diff -u в %s: '%s'"

#: scripts/Dpkg/Source/Patch.pm
msgid "failed to write"
msgstr "не вдалося записати"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "diff on %s"
msgstr "diff у %s"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "cannot stat file %s"
msgstr "не вдалося виконати stat до файлу %s"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "cannot read link %s"
msgstr "не вдалося прочитати посилання %s"

#: scripts/Dpkg/Source/Patch.pm
msgid "device or socket is not allowed"
msgstr "пристрій або сокет не допускається"

#: scripts/Dpkg/Source/Patch.pm
msgid "unknown file type"
msgstr "невідомий тип файлу"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "ignoring deletion of file %s"
msgstr "ігнорую видалення файлу %s"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "ignoring deletion of file %s, use --include-removal to override"
msgstr ""
"ігнорую видалення файлу %s, використовуйте --include-removal для "
"перевизначення"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "ignoring deletion of directory %s"
msgstr "ігнорую видалення каталогу %s"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "ignoring deletion of symlink %s"
msgstr "ігнорую видалення символічного посилання %s"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "newly created empty file '%s' will not be represented in diff"
msgstr "новостворений порожній файл '%s' не буде представлений у diff"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "executable mode %04o of '%s' will not be represented in diff"
msgstr "виконуваний режим %04o для '%s' не буде представлений в diff"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "special mode %04o of '%s' will not be represented in diff"
msgstr "спеціальний режим %04o для '%s' не буде представлений в diff"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "cannot represent change to %s:"
msgstr "не вдалося відобразити зміну %s:"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "  new version is %s"
msgstr "  нова версія - %s"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "  old version is %s"
msgstr "  стара версія - %s"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "diff %s patches file with C-style encoded filename"
msgstr "diff %s містить патч для файлу з іменем, закодованим у стилі C"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "expected ^--- in line %d of diff '%s'"
msgstr "очікувалося ^--- у рядку %d diff '%s'"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "diff '%s' patches file with name ending in .dpkg-orig"
msgstr ""
"diff '%s' містить патч для файлу з іменем, що закінчується на .dpkg-orig"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "diff '%s' finishes in middle of ---/+++ (line %d)"
msgstr "diff '%s' завершується посередині ---/+++ (рядок %d)"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "line after --- is not as expected in diff '%s' (line %d)"
msgstr "рядок після --- не відповідає очікуванням у diff '%s' (рядок %d)"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "none of the filenames in ---/+++ are valid in diff '%s' (line %d)"
msgstr "жодне з імен файлів у ---/+++ не є коректним у diff '%s' (рядок %d)"

#: scripts/Dpkg/Source/Patch.pm scripts/Dpkg/Source/Quilt.pm
#, perl-format
msgid "%s contains an insecure path: %s"
msgstr "%s містить небезпечний шлях: %s"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "diff %s modifies file %s through a symlink: %s"
msgstr "diff %s змінює файл %s через символічне посилання: %s"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "original and modified files are /dev/null in diff '%s' (line %d)"
msgstr "оригінальний та змінений файли є /dev/null у diff '%s' (рядок %d)"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "file removal without proper filename in diff '%s' (line %d)"
msgstr "видалення файлу без належної назви файлу в diff '%s' (рядок %d)"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "diff %s removes a non-existing file %s (line %d)"
msgstr "diff %s видаляє неіснуючий файл %s (рядок %d)"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "diff '%s' patches something which is not a plain file"
msgstr "diff '%s' патчить щось, що не є звичайним файлом"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "diff '%s' patches hard link %s which can have unintended consequences"
msgstr ""
"diff '%s' патчить жорстке посилання %s, що може мати непередбачувані наслідки"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid ""
"diff '%s' patches files multiple times; split the diff in multiple files or "
"merge the hunks into a single one"
msgstr ""
"diff '%s' патчить файли кілька разів; розділіть diff на кілька файлів або "
"об'єднайте фрагменти в один"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "diff '%s' patches file %s more than once"
msgstr "diff '%s' патчить файл %s більше одного разу"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "unexpected end of diff '%s'"
msgstr "неочікуваний кінець diff '%s'"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "expected [ +-] at start of line %d of diff '%s'"
msgstr "очікувалося [ +-] на початку рядка %d diff '%s'"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "expected ^@@ at line %d of diff '%s'"
msgstr "очікувалося ^@@ у рядку %d diff '%s'"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "diff '%s' does not contain any patch"
msgstr "diff '%s' не містить жодного патчу"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "remove patch backup file %s"
msgstr "видаляю файл резервної копії патча %s"

#: scripts/Dpkg/Source/Patch.pm
msgid "nonexistent"
msgstr "неіснуючий"

#: scripts/Dpkg/Source/Patch.pm
msgid "plain file"
msgstr "звичайний файл"

#: scripts/Dpkg/Source/Patch.pm
msgid "directory"
msgstr "каталог"

#: scripts/Dpkg/Source/Patch.pm
#, perl-format
msgid "symlink to %s"
msgstr "символічне посилання на %s"

#: scripts/Dpkg/Source/Patch.pm
msgid "block device"
msgstr "блочний пристрій"

#: scripts/Dpkg/Source/Patch.pm
msgid "character device"
msgstr "символьний пристрій"

#: scripts/Dpkg/Source/Patch.pm
msgid "named pipe"
msgstr "іменований канал"

#: scripts/Dpkg/Source/Patch.pm
msgid "named socket"
msgstr "іменований сокет"

#: scripts/Dpkg/Source/Quilt.pm
#, perl-format
msgid "cannot mkdir %s"
msgstr "не вдалося mkdir %s"

#: scripts/Dpkg/Source/Quilt.pm
msgid "the patch has fuzz which is not allowed, or is malformed"
msgstr "патч містить недозволений fuzz або є некоректним"

#: scripts/Dpkg/Source/Quilt.pm
#, perl-format
msgid "if patch '%s' is correctly applied by quilt, use '%s' to update it"
msgstr ""
"якщо quilt правильно застосував патч '%s', використовуйте '%s' для його "
"оновлення"

#: scripts/Dpkg/Source/Quilt.pm
msgid ""
"if the file is present in the unpacked source, make sure it is also present "
"in the orig tarball"
msgstr ""
"якщо файл присутній у розпакованому вихідному коді, переконайтеся, що він "
"також присутній у вихідному tar-архіві"

#: scripts/Dpkg/Source/Quilt.pm
#, perl-format
msgid "%s should be a directory or non-existing"
msgstr "%s має бути каталогом або не має існувати"

#: scripts/Dpkg/Source/Quilt.pm
#, perl-format
msgid "%s should be a file or non-existing"
msgstr "%s має бути файлом або не має існувати"

#: scripts/Dpkg/Source/Quilt.pm
#, perl-format
msgid ""
"the series file (%s) contains unsupported options ('%s', line %s); dpkg-"
"source might fail when applying patches"
msgstr ""
"файл серії (%s) містить непідтримувані параметри ('%s', рядок %s); dpkg-"
"source може завершитися помилкою під час застосування патчів"

#: scripts/Dpkg/Source/Quilt.pm
#, perl-format
msgid "restoring quilt backup files for %s"
msgstr "відновлення резервних копій файлів quilt для %s"

#: scripts/Dpkg/Substvars.pm
#, perl-format
msgid "bad line in substvars file %s at line %d"
msgstr "неправильний рядок у файлі substvars %s у рядку %d"

#: scripts/Dpkg/Substvars.pm
#, perl-format
msgid "invalid source version %s"
msgstr "недійсна вихідна версія %s"

#: scripts/Dpkg/Substvars.pm
#, perl-format
msgid "too many ${%s} substitutions (recursive?) in '%s'"
msgstr "забагато підстановок ${%s} (рекурсивних?) у '%s'"

#: scripts/Dpkg/Substvars.pm
#, perl-format
msgid "obsolete substitution variable ${%s}"
msgstr "застаріла змінна підстановки ${%s}"

#: scripts/Dpkg/Substvars.pm
#, perl-format
msgid "substitution variable ${%s} used, but is not defined"
msgstr "змінна підстановки ${%s} використовується, але не визначена"

#: scripts/Dpkg/Substvars.pm
#, perl-format
msgid "required substitution variable ${%s} not used"
msgstr "обов'язкова змінна підстановки ${%s} не використовується"

#: scripts/Dpkg/Substvars.pm
#, perl-format
msgid "substitution variable ${%s} unused, but is defined"
msgstr "змінна підстановки ${%s} не використовується, але визначена"

#: scripts/Dpkg/Vendor/Debian.pm
#, perl-format
msgid "unknown host architecture '%s'"
msgstr "невідома архітектура хоста '%s'"

#: scripts/Dpkg/Vendor/Debian.pm
#, perl-format
msgid "unknown abi attributes for architecture '%s'"
msgstr "невідомі атрибути ABI для архітектури '%s'"

#: scripts/Dpkg/Vendor/PureOS.pm scripts/Dpkg/Vendor/Ubuntu.pm
#, perl-format
msgid "version number suggests %s vendor changes, but there is no %s field"
msgstr "номер версії вказує на %s змін постачальника, але поле %s відсутнє"

#: scripts/Dpkg/Vendor/Ubuntu.pm
#, perl-format
msgid ""
"version number suggests %s vendor changes, but the %s field does not have %s "
"vendor address"
msgstr ""
"номер версії вказує на %s змін постачальника, але поле %s не містить адреси "
"постачальника %s"

#: scripts/Dpkg/Version.pm
#, perl-format
msgid "%s is not a valid version"
msgstr "%s не є дійсною версією"

#: scripts/Dpkg/Version.pm
msgid "version number cannot be empty"
msgstr "номер версії не може бути порожнім"

#: scripts/Dpkg/Version.pm
msgid "epoch part of the version number cannot be empty"
msgstr "частина номера версії epoch не може бути порожньою"

#: scripts/Dpkg/Version.pm
msgid "upstream version cannot be empty"
msgstr "upstream-версія не може бути порожньою"

#: scripts/Dpkg/Version.pm
msgid "revision cannot be empty"
msgstr "ревізія не може бути порожньою"

#: scripts/Dpkg/Version.pm
msgid "version number does not start with digit"
msgstr "номер версії не починається з цифри"

#: scripts/Dpkg/Version.pm
#, perl-format
msgid "version number contains invalid character '%s'"
msgstr "номер версії містить неприпустимий символ '%s'"

#: scripts/Dpkg/Version.pm
#, perl-format
msgid "epoch part of the version number is not a number: '%s'"
msgstr "частина epoch у номері версії не є числом: '%s'"

msgstr "%s потребує параметра"

#: scripts/dpkg-buildpackage.pl
#, perl-format
msgid "Usage: %s [<option>...] [--] [<filename.dsc>|<directory>]"
msgstr "Використання: %s [<параметр>...] [--] [<ім'я_файлу.dsc>|<каталог>]"

#: scripts/dpkg-buildpackage.pl
msgid ""
"Options:\n"
"      --build=<type>[,...]    specify the build <type>: full, source, "
"binary,\n"
"                                any, all (default is 'full').\n"
"  -F, --build=full            normal full build (source and binary; "
"default).\n"
"  -g, --build=source,all      source and arch-indep build.\n"
"  -G, --build=source,any      source and arch-specific build.\n"
"  -b, --build=binary          binary-only, no source files.\n"
"  -B, --build=any             binary-only, only arch-specific files.\n"
"  -A, --build=all             binary-only, only arch-indep files.\n"
"  -S, --build=source          source-only, no binary files.\n"
"  -nc, --no-pre-clean         do not pre clean source tree (implies -b).\n"
"      --pre-clean             pre clean source tree (default).\n"
"      --no-post-clean         do not post clean source tree (default).\n"
"  -tc, --post-clean           post clean source tree.\n"
"      --sanitize-env          sanitize the build environment.\n"
"  -D, --check-builddeps       check build dependencies and conflicts "
"(default).\n"
"  -d, --no-check-builddeps    do not check build dependencies and "
"conflicts.\n"
"      --ignore-builtin-builddeps\n"
"                              do not check builtin build dependencies.\n"
"  -P, --build-profiles=<profiles>\n"
"                              assume comma-separated build <profiles> as "
"active.\n"
"      --rules-requires-root   assume legacy Rules-Requires-Root field "
"value.\n"
"  -R, --rules-file=<rules>    rules file to execute (default is debian/"
"rules).\n"
"  -T, --rules-target=<target> call debian/rules <target>.\n"
"      --as-root               ensure -T calls the target with root rights.\n"
"  -j, --jobs[=<jobs>|auto]    jobs to run simultaneously (passed to "
"<rules>),\n"
"                                (default; default is auto, opt-in mode).\n"
"  -J, --jobs-try[=<jobs>|auto]\n"
"                              alias for -j, --jobs.\n"
"      --jobs-force[=<jobs>|auto]\n"
"                              jobs to run simultaneously (passed to "
"<rules>),\n"
"                                (default is auto, forced mode).\n"
"  -r, --root-command=<command>\n"
"                              command to gain root rights (default is "
"fakeroot).\n"
"      --check-command=<command>\n"
"                              command to check the .changes file (no "
"default).\n"
"      --check-option=<opt>    pass <opt> to check <command>.\n"
"      --hook-<name>=<command> set <command> as the hook <name>, known "
"hooks:\n"
"                                preinit init preclean source build binary\n"
"                                buildinfo changes postclean check sign done\n"
"      --buildinfo-file=<file> set the .buildinfo filename to generate.\n"
"      --buildinfo-option=<opt>\n"
"                              pass option <opt> to dpkg-genbuildinfo.\n"
"      --changes-file=<file>   set the .changes filename to generate.\n"
"      --sign-backend=<backend>\n"
"                              OpenPGP backend to use to sign\n"
"                                (default is auto).\n"
"  -p, --sign-command=<command>\n"
"                              command to sign .dsc and/or .changes files\n"
"                                (default is gpg).\n"
"      --sign-keyfile=<file>   the key file to use for signing.\n"
"  -k, --sign-keyid=<keyid>    the key id to use for signing.\n"
"      --sign-key=<keyid>      alias for -k, --sign-keyid.\n"
"  -ap, --sign-pause           add pause before starting signature process.\n"
"  -us, --unsigned-source      unsigned source package.\n"
"  -ui, --unsigned-buildinfo   unsigned .buildinfo file.\n"
"  -uc, --unsigned-changes     unsigned .buildinfo and .changes file.\n"
"      --no-sign               do not sign any file.\n"
"      --force-sign            force signing the resulting files.\n"
"      --admindir=<directory>  change the administrative directory.\n"
"  -?, --help                  show this help message.\n"
"      --version               show the version."
msgstr ""
"Параметри:\n"
"  --build=<тип>[,...]      вказати тип збірки: full, source, binary,\n"
"                                        any, all (типово 'full').\n"
"  -F, --build=full         звичайна повна збірка (вихідний код та бінарний "
"код; типово).\n"
"  -g, --build=source,all   збірка вихідного коду та незалежних від "
"архітектури файлів.\n"
"  -G, --build=source,any   збірка вихідного коду та прив’язаних до "
"архітектури файлів.\n"
"  -b, --build=binary       лише бінарні файли, без вихідних.\n"
"  -B, --build=any          лише бінарні файли, лише прив’язані до "
"архітектури.\n"
"  -A, --build=all          лише бінарні файли, лише незалежні від "
"архітектури.\n"
"  -S, --build=source       лише вихідний код, без бінарних файлів.\n"
"  -nc, --no-pre-clean      не очищати попередньо дерево вихідних кодів\n"
"                                        (мається на увазі -b).\n"
"  --pre-clean              попередньо очищати дерево вихідних кодів "
"(типово).\n"
"  --no-post-clean          не очищувати дерево вихідних кодів після "
"завершення (типово).\n"
"  -tc, --post-clean        очищувати дерево вихідних кодів після "
"завершення.\n"
"  --sanitize-env           очищувати середовище збірки.\n"
"  -D, --check-builddeps    перевіряти залежності та конфлікти збірки "
"(типово).\n"
"  -d, --no-check-builddeps не перевіряти залежності та конфлікти збірки.\n"
"  --ignore-builtin-builddeps\n"
"                           не перевіряти вбудовані залежності збірки.\n"
"  -P, --build-profiles=<профілі>\n"
"                           вважати активними профілі збірки, розділені "
"комами.\n"
"  --rules-requires-root    вважати чинним значення застарілого\n"
"                                        поля Rules-Requires-Root.\n"
"  -R, --rules-file=<правила>\n"
"                           файл правил для виконання (типово debian/rules).\n"
"  -T, --rules-target=<ціль>викликати debian/rules <ціль>.\n"
"      --as-root            забезпечити виклик цілі через -T з правами root.\n"
"  -j, --jobs[=<кількість>|auto]\n"
"                           кількість завдань для одночасного\n"
"                                        виконання (передається до "
"<правила>),\n"
"                                        (типово; типово auto, режим opt-"
"in).\n"
"  -J, --jobs-try[=<кількість>|auto]\n"
"                           псевдонім для -j, --jobs.\n"
"  --jobs-force[=<кількість>|auto]\n"
"                           кількість завдань для одночасного виконання "
"(передається\n"
"                                        до <правила>), (типово auto, "
"примусовий режим).\n"
"  -r, --root-command=<команда>\n"
"                           команда для отримання root-прав (типово "
"fakeroot).\n"
"  --check-command=<команда>команда для перевірки файлу .changes\n"
"                                        (типового значення немає).\n"
"  --check-option=<опція>   передати <опція> до команди перевірки.\n"
"  --hook-<ім'я>=<команда>  встановити <команда> як перехоплювач <ім'я>,\n"
"                                        відомі перехоплювачі:\n"
"                                        preinit init preclean source build "
"binary\n"
"                                        buildinfo changes postclean check "
"sign done\n"
"  --buildinfo-file=<файл>  встановити ім'я файлу .buildinfo для створення.\n"
"  --buildinfo-option=<опція>\n"
"                           передати опцію <опція> до dpkg-genbuildinfo.\n"
"  --changes-file=<файл>    встановити ім'я файлу .changes для створення.\n"
"  --sign-backend=<бекенд>  бекенд OpenPGP для підпису (типово авто).\n"
"  -p, --sign-command=<команда>\n"
"                           команда для підпису файлів .dsc та/або .changes\n"
"                                        (типово gpg).\n"
"  --sign-keyfile=<файл>    файл ключа для підпису.\n"
"  -k, --sign-keyid=<ID ключа>\n"
"                           ідентифікатор ключа для підпису.\n"
"  --sign-key=<ID ключа>    псевдонім для -k, --sign-keyid.\n"
"  -ap, --sign-pause        додати паузу перед початком процесу підпису.\n"
"  -us, --unsigned-source   непідписаний вихідний пакунок.\n"
"  -ui, --unsigned-buildinfoнепідписаний файл .buildinfo.\n"
"  -uc, --unsigned-changes  непідписані файли .buildinfo та .changes.\n"
"  --no-sign                не підписувати жодних файлів.\n"
"  --force-sign             примусово підписувати створені файли.\n"
"  --admindir=<каталог>     змінити адміністративний каталог.\n"
"  -?, --help               показати це довідкове повідомлення.\n"
"  --version                показати версію."

#: scripts/dpkg-buildpackage.pl
msgid ""
"Options passed to dpkg-architecture:\n"
"  -a, --host-arch <arch>      set the host Debian architecture.\n"
"  -t, --host-type <type>      set the host GNU system type.\n"
"      --target-arch <arch>    set the target Debian architecture.\n"
"      --target-type <type>    set the target GNU system type."
msgstr ""
"Параметри, що передаються до dpkg-architecture:\n"
"  -a, --host-arch <арх>    встановити архітектуру Debian хоста.\n"
"  -t, --host-type <тип>    встановити тип системи GNU хоста.\n"
"      --target-arch <арх>  встановити цільову архітектуру Debian.\n"
"      --target-type <тип>  встановити цільовий тип системи GNU."

#: scripts/dpkg-buildpackage.pl
msgid ""
"Options passed to dpkg-genchanges:\n"
"  -si                         source includes orig, if new upstream "
"(default).\n"
"  -sa                         source includes orig, always.\n"
"  -sd                         source is diff and .dsc only.\n"
"  -v<version>                 changes since version <version>.\n"
"  -m, --source-by=<maint>     maintainer for this source or build is "
"<maint>.\n"
"      --build-by=<maint>      ditto.\n"
"  -e, --release-by=<maint>    maintainer for this change or release is "
"<maint>.\n"
"      --changed-by=<maint>    ditto.\n"
"  -C<descfile>                changes are described in <descfile>.\n"
"      --changes-option=<opt>  pass option <opt> to dpkg-genchanges."
msgstr ""
"Параметри, що передаються до dpkg-genchanges:\n"
"  -si                      вихідний код містить orig, якщо новий upstream "
"(типово).\n"
"  -sa                      вихідний код містить orig, завжди.\n"
"  -sd                      вихідний код - це diff та лише .dsc.\n"
"  -v<версія>               зміни з версії <версія>.\n"
"  -m, --source-by=<maint>  супроводжувач цього джерела або збірки - "
"<maint>.\n"
"  --build-by=<maint>       те саме.\n"
"  -e, --release-by=<maint> супроводжувач для цієї зміни або релізу - "
"<maint>.\n"
"  --changed-by=<maint>     те саме.\n"
"  -C<файл-опису>           зміни описано в <файл-опису>.\n"
"  --changes-option=<опція> передати опцію <опція> до dpkg-genchanges."

#: scripts/dpkg-buildpackage.pl
msgid ""
"Options passed to dpkg-source:\n"
"  -sn                         force Debian native source format.\n"
"  -s[sAkurKUR]                see dpkg-source for explanation.\n"
"  -z, --compression-level=<level>\n"
"                              compression level to use for source.\n"
"  -Z, --compression=<compressor>\n"
"                              compression to use for source (gz|xz|bzip2|"
"lzma).\n"
"  -i, --diff-ignore[=<regex>] ignore diffs of files matching <regex>.\n"
"  -I, --tar-ignore[=<pattern>]\n"
"                              filter out files when building tarballs.\n"
"      --source-option=<opt>   pass option <opt> to dpkg-source.\n"
msgstr ""
"Параметри, що передаються до dpkg-source:\n"
"  -sn                      примусово використовувати рідний формат вихідного "
"коду Debian.\n"
"  -s[sAkurKUR]            див. dpkg-source для пояснення.\n"
"  -z, --compression-level=<рівень>\n"
"                           рівень стиснення для вихідного коду.\n"
"  -Z, --compression=<компресор>\n"
"                           спосіб стиснення для вихідного коду (gz|xz|bzip2|"
"lzma).\n"
"  -i, --diff-ignore[=<регулярний_вираз>]\n"
"                           ігнорувати відмінності файлів,\n"
"                                        що відповідають <регулярний_вираз>.\n"
"  -I, --tar-ignore[=<шаблон>]\n"
"                           фільтрувати файли під час створення tar-архівів.\n"
"  --source-option=<опція>  передати опцію <опція> до dpkg-source.\n"


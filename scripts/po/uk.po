#, perl-format
msgid "Usage: %s [<option>...] [<command>]"
msgstr "Використання: %s [<параметр>...] [<команда>]"

#: scripts/dpkg-architecture.pl
msgid ""
"Commands:\n"
"  -l, --list                list variables (default).\n"
"  -L, --list-known          list valid architectures (matching some "
"criteria).\n"
"  -e, --equal <arch>        compare with host Debian architecture.\n"
"  -i, --is <arch-wildcard>  match against host Debian architecture.\n"
"  -q, --query <variable>    prints only the value of <variable>.\n"
"  -s, --print-set           print command to set environment variables.\n"
"  -u, --print-unset         print command to unset environment variables.\n"
"  -c, --command <command>   set environment and run the command in it.\n"
"  -?, --help                show this help message.\n"
"      --version             show the version."
msgstr ""
"Команди:\n"
"  -l, --list               вивести список змінних (типово).\n"
"  -L, --list-known         вивести список дійсних архітектур\n"
"                                        (що відповідають певним критеріям).\n"
"  -e, --equal <арх>        порівняти з архітектурою Debian хоста.\n"
"  -i, --is <шаблон-арх>    зіставити з архітектурою Debian хоста.\n"
"  -q, --query <змінна>     виводить лише значення <змінна>.\n"
"  -s, --print-set          вивести команду для встановлення змінних "
"середовища.\n"
"  -u, --print-unset        вивести команду для скасування змінних "
"середовища.\n"
"  -c, --command <команда>  встановити середовище та виконати\n"
"                                        команду в ньому.\n"
"  -?, --help               показати це довідкове повідомлення.\n"
"    --version              показати версію."

#: scripts/dpkg-architecture.pl
msgid ""
"Options:\n"
"  -a, --host-arch <arch>    set host Debian architecture.\n"
"  -t, --host-type <type>    set host GNU system type.\n"
"  -A, --target-arch <arch>  set target Debian architecture.\n"
"  -T, --target-type <type>  set target GNU system type.\n"
"  -W, --match-wildcard <arch-wildcard>\n"
"                            restrict architecture list matching <arch-"
"wildcard>.\n"
"  -B, --match-bits <arch-bits>\n"
"                            restrict architecture list matching <arch-"
"bits>.\n"
"  -E, --match-endian <arch-endian>\n"
"                            restrict architecture list matching <arch-"
"endian>.\n"
"      --print-format <format>\n"
"                            use <format> for --print-set and --print-unset,\n"
"                              allowed values: shell (default), make.\n"
"  -f, --force               force flag (override variables set in "
"environment)."
msgstr ""
"Параметри:\n"
"  -a, --host-arch <арх>    встановити архітектуру Debian хоста.\n"
"  -t, --host-type <тип>    встановити тип системи GNU хоста.\n"
"  -A, --target-arch <арх>  встановити цільову архітектуру Debian.\n"
"  -T, --target-type <тип>  встановити цільовий тип системи GNU.\n"
"  -W, --match-wildcard <шаблон-арх>\n"
"                           обмежити список архітектур, що відповідають "
"<шаблон-арх>\n"
"  -B, --match-bits <біти>  обмежити список архітектур за кількістю біт.\n"
"  -E, --match-endian <ендіан>\n"
"                           обмежити список архітектур за порядком байтів.\n"
"  --print-format <формат>  використовувати <формат> для --print-set та --"
"print-unset;\n"
"                                        дозволені значення: shell (типово), "
"make.\n"
"  -f, --force              примусово встановити прапорець\n"
"                                        (перевизначити змінні середовища)."


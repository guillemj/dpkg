#: scripts/dpkg-source.pl
#, perl-format
msgid "Usage: %s [<option>...] <command>"
msgstr "Використання: %s [<параметр>...] <команда>"

#: scripts/dpkg-source.pl
msgid ""
"Commands:\n"
"  -x, --extract <filename>.dsc [<output-dir>]\n"
"                           extract source package.\n"
"  -b, --build <dir>        build source package.\n"
"      --print-format <dir> print the format to be used for the source "
"package.\n"
"      --before-build <dir> run the corresponding source package format "
"hook.\n"
"      --after-build <dir>  run the corresponding source package format "
"hook.\n"
"      --commit [<dir> [<patch-name>]]\n"
"                           store upstream changes in a new patch."
msgstr ""
"Команди:\n"
"  -x, --extract <ім'я файлу>.dsc [<каталог-виводу>]\n"
"                           видобути пакунок з вихідним кодом.\n"
"  -b, --build <каталог>    зібрати пакунок з вихідним кодом.\n"
"  --print-format <каталог> вивести формат, який буде\n"
"                                        використано для пакунка з вихідним "
"кодом.\n"
"  --before-build <каталог> виконати відповідний виклик\n"
"                                        формату пакунка з вихідним кодом.\n"
"  --after-build <каталог>  виконати відповідний виклик\n"
"                                        формату пакунка з вихідним кодом.\n"
"  --commit [<каталог> [<назва-патча>]]\n"
"                           зберегти зміни upstream у новому патчі."

#: scripts/dpkg-source.pl
#, perl-format
msgid ""
"Build options:\n"
"  -c<control-file>         get control info from this file.\n"
"  -l<changelog-file>       get per-version info from this file.\n"
"  -F<changelog-format>     force changelog format.\n"
"  --format=<source-format> set the format to be used for the source "
"package.\n"
"  -V<name>=<value>         set a substitution variable.\n"
"  -T<substvars-file>       read variables here.\n"
"  -D<field>=<value>        override or add a .dsc field and value.\n"
"  -U<field>                remove a field.\n"
"  -i, --diff-ignore[=<regex>]\n"
"                           filter out files to ignore diffs of\n"
"                             (defaults to: '%s').\n"
"  -I, --tar-ignore[=<pattern>]\n"
"                           filter out files when building tarballs\n"
"                             (defaults to: %s).\n"
"  -Z, --compression=<compression>\n"
"                           select compression to use (defaults to '%s',\n"
"                             supported are: %s).\n"
"  -z, --compression-level=<level>\n"
"                           compression level to use (defaults to '%d',\n"
"                             supported are: '1'-'9', 'best', 'fast')"
msgstr ""
"Параметри збірки:\n"
"  -c<файл-керування>       отримати інформацію про керування з цього файлу.\n"
"  -l<файл-змін>            отримати інформацію для кожної версії з цього "
"файлу.\n"
"  -F<формат-змін>          примусово встановити формат журналу змін.\n"
"  --format=<формат-вихідного-пакунка>\n"
"                           встановити формат, який буде використовуватися\n"
"                                        для вихідного пакунка.\n"
"  -V<назва>=<значення>     встановити змінну підстановки.\n"
"  -T<файл-підзмінних>      зчитати змінні тут.\n"
"  -D<поле>=<значення>      перевизначити або додати поле .dsc\n"
"                                        із його значенням.\n"
"  -U<поле>                 видалити поле.\n"
"  -i, --diff-ignore[=<регулярний-вираз>]\n"
"                           відфільтрувати файли, щоб ігнорувати відмінності\n"
"                                        (типово: '%s').\n"
"  -I, --tar-ignore[=<шаблон>]\n"
"                           відфільтрувати файли під час збірки tar-архівів\n"
"                                        (типово: %s).\n"
"  -Z, --compression=<стиснення>\n"
"                           вибрати алгоритм стиснення (типово '%s',\n"
"                                        підтримуються: %s).\n"
"-z, --compression-level=<рівень>\n"
"                           рівень стиснення (типово '%d',\n"
"                                        підтримуються: '1'-'9', 'best', "
"'fast')"

#: scripts/dpkg-source.pl
msgid ""
"Extract options:\n"
"  --no-copy                do not copy .orig tarballs\n"
"  --no-check               do not check signature and checksums on "
"extraction\n"
"  --no-overwrite-dir       do not overwrite directory on extraction\n"
"  --no-vendor-certs        do not use vendor specific certificate keyrings\n"
"  --signer-certs=<keyring> use a signer certificates keyring\n"
"  --require-valid-signature\n"
"                           abort if the package does not have a valid "
"signature\n"
"  --require-strong-checksums\n"
"                           abort if the package contains no strong "
"checksums\n"
"  --ignore-bad-version     allow bad source package versions."
msgstr ""
"Параметри видобування:\n"
"  --no-copy                не копіювати .orig tar-архіви\n"
"  --no-check               не перевіряти підпис та контрольні суми під час "
"видобування\n"
"  --no-overwrite-dir       не перезаписувати каталог під час видобування\n"
"  --no-vendor-certs        не використовувати в'язки ключів сертифікатів,\n"
"                                        специфічних для постачальника\n"
"  --signer-certs=<в'язка>  використовувати в'язку ключів сертифікатів "
"підписувача\n"
"  --require-valid-signatureперервати, якщо пакунок не має дійсного підпису\n"
"  --require-strong-checksums\n"
"                           перервати, якщо пакунок не містить надійних "
"контрольних сум\n"
"  --ignore-bad-version     дозволити неправильні версії вихідного пакунка."

#: scripts/dpkg-source.pl
msgid ""
"General options:\n"
"      --threads-max=<threads>\n"
"                           use at most <threads> with compressor.\n"
"  -q                       quiet mode.\n"
"  -?, --help               show this help message.\n"
"      --version            show the version."
msgstr ""
"Загальні параметри:\n"
"  --threads-max=<потоки>   використовувати не більше <потоків> з "
"компресором.\n"
"  -q                       тихий режим.\n"
"  -?, --help               показати це довідкове повідомлення.\n"
"  --version                показати версію."

#: scripts/dpkg-source.pl
msgid ""
"Source format specific build and extract options are available;\n"
"use --format with --help to see them."
msgstr ""
"Доступні параметри збірки та розпакування, що відповідають\n"
"певному формату вихідного пакунка; використовуйте --format\n"
"з --help, щоб їх побачити."

#: scripts/dpkg-vendor.pl
msgid ""
"Commands:\n"
"  --is <vendor>           returns true if current vendor is <vendor>.\n"
"  --derives-from <vendor> returns true if current vendor derives from "
"<vendor>.\n"
"  --query <field>         print the content of the vendor-specific field.\n"
"  --help                  show this help message.\n"
"  --version               show the version."
msgstr ""
"Команди:\n"
"  --is <постачальник>      повертає true, якщо поточний\n"
"                                        постачальник є <постачальник>.\n"
"  --derives-from <постачальник>\n"
"                           повертає true, якщо поточний постачальник "
"походить\n"
"                                       від <постачальник>.\n"
"  --query <поле>           вивести вміст поля, специфічного для "
"постачальника.\n"
"  --help                   показати це довідкове повідомлення.\n"
"  --version                показати версію."

#: scripts/dpkg-vendor.pl
msgid ""
"Options:\n"
"  --vendor <vendor>       assume <vendor> is the current vendor."
msgstr ""
"Параметри:\n"
"  --vendor <постачальник>  вважати <постачальник>\n"
"                                        поточним постачальником."


#: scripts/dpkg-shlibdeps.pl
msgid ""
"Positional options (order is significant):\n"
"  <executable>             include dependencies for <executable>,\n"
"  -e<executable>           (use -e if <executable> starts with '-')\n"
"  -d<dependency-field>     next executable(s) set shlibs:<dependency-field>."
msgstr ""
"Позиційні параметри (порядок має значення):\n"
"  <виконуваний файл>        включити залежності для <виконуваний файл>,\n"
"  -e<виконуваний файл>     (використовуйте -e, якщо <виконуваний файл> "
"починається з '-')\n"
"  -d<поле-залежності>      наступний(і) виконуваний(і) файл(и) встановити як "
"shlibs:<поле-залежності>."

#: scripts/dpkg-shlibdeps.pl
msgid ""
"Options:\n"
"  --package=<package>      generate substvars for <package> (default is "
"unset).\n"
"  -l<library-dir>          add directory to private shared library search "
"list.\n"
"  -p<varname-prefix>       set <varname-prefix>:* instead of shlibs:*.\n"
"  -O[<file>]               write variable settings to stdout (or <file>).\n"
"  -L<local-shlibs-file>    shlibs override file, not debian/shlibs.local.\n"
"  -T<substvars-file>       update variables here, not debian/substvars.\n"
"  -t<type>                 set package type (default is deb).\n"
"  -x<package>              exclude package from the generated dependencies.\n"
"  -S<package-build-dir>    search needed libraries in the given\n"
"                             package build directory first.\n"
"  -I<package-build-dir>    ignore needed libraries, shlibs and symbols "
"files\n"
"                             in the given build directory.\n"
"  -v                       enable verbose mode (can be used multiple "
"times).\n"
"  --ignore-missing-info    do not fail on missing dependency information.\n"
"  --warnings=<value>       define set of active warnings (see manual page).\n"
"  --admindir=<directory>   change the administrative directory.\n"
"  -?, --help               show this help message.\n"
"      --version            show the version."
msgstr ""
"Параметри:\n"
"  --package=<пакунок>       генерувати підзмінні для <пакунок>\n"
"                                        (типово не встановлено).\n"
"  -l<каталог-бібліотеки>   додати каталог до списку пошуку\n"
"                                        приватних спільних бібліотек.\n"
"  -p<префікс-змінної>      встановити <префікс-змінної>:* замість shlibs:*.\n"
"  -O[<файл>]               записати налаштування змінних у stdout (або "
"<файл>).\n"
"  -L<локальний-файл-shlibs>файл перевизначення shlibs, а не debian/"
"shlibs.local.\n"
"  -T<файл-підзмінних>      оновити змінні тут, а не в debian/substvars.\n"
"  -t<тип>                  встановити тип пакунка (типово deb).\n"
"  -x<пакунок>              виключити пакунок зі згенерованих залежностей.\n"
"  -S<каталог-збірки-пакунка>\n"
"                           спочатку шукати потрібні бібліотеки\n"
"                                        у заданому каталозі збірки пакунка.\n"
"  -I<каталог-збірки-пакунка>\n"
"                           ігнорувати необхідні бібліотеки, shlibs та файли\n"
"                                        символів у заданому каталозі "
"збірки.\n"
"  -v                       увімкнути детальний режим\n"
"                                        (можна використовувати кілька "
"разів).\n"
"  --ignore-missing-info    не завершуватися помилкою, якщо\n"
"                                        інформація про залежності відсутня.\n"
"  --warnings=<значення>    визначає набір активних попереджень\n"
"                                        (див. сторінку довідки).\n"
"  --admindir=<каталог>     змінити адміністративний каталог.\n"
"  -?, --help               показати це довідкове повідомлення.\n"
"  --version                показати версію."


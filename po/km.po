"  -i|--install       <.deb file name>... | -R|--recursive <directory>...\n"
"  --unpack           <.deb file name>... | -R|--recursive <directory>...\n"
"  -A|--record-avail  <.deb file name>... | -R|--recursive <directory>...\n"
"  --configure        <package>... | -a|--pending\n"
"  --triggers-only    <package>... | -a|--pending\n"
"  -r|--remove        <package>... | -a|--pending\n"
"  -P|--purge         <package>... | -a|--pending\n"
"  -V|--verify [<package>...]       Verify the integrity of package(s).\n"
"  --get-selections [<pattern>...]  Get list of selections to stdout.\n"
"  --set-selections                 Set package selections from stdin.\n"
"  --clear-selections               Deselect every non-essential package.\n"
"  --update-avail [<Packages-file>] Replace available packages info.\n"
"  --merge-avail [<Packages-file>]  Merge with info from file.\n"
"  --clear-avail                    Erase existing available info.\n"
"  --forget-old-unavail             Forget uninstalled unavailable pkgs.\n"
"  -s|--status [<package>...]       Display package status details.\n"
"  -p|--print-avail [<package>...]  Display available version details.\n"
"  -L|--listfiles <package>...      List files 'owned' by package(s).\n"
"  -l|--list [<pattern>...]         List packages concisely.\n"
"  -S|--search <pattern>...         Find package(s) owning file(s).\n"
"  -C|--audit [<package>...]        Check for broken package(s).\n"
"  --yet-to-unpack                  Print packages selected for "
"installation.\n"
"  --predep-package                 Print pre-dependencies to unpack.\n"
"  --add-architecture <arch>        Add <arch> to the list of architectures.\n"
"  --remove-architecture <arch>     Remove <arch> from the list of "
"architectures.\n"
"  --print-architecture             Print dpkg architecture.\n"
"  --print-foreign-architectures    Print allowed foreign architectures.\n"
"  --assert-help                    Show help on assertions.\n"
"  --assert-<feature>               Assert support for the specified "
"feature.\n"
"  --validate-<thing> <string>      Validate a <thing>'s <string>.\n"
"  --compare-versions <a> <op> <b>  Compare version numbers - see below.\n"
"  --force-help                     Show help on forcing.\n"
"  -Dh|--debug=help                 Show help on debugging.\n"
"\n"
msgstr ""
"бһ–бһ¶бһҖбҹ’бһҷбһ”бһүбҹ’бһҮбһ¶В бҹ–\n"
"  -i|--install       <.deb file name> ... | -R|--recursive <бһҗбһҸ> ...\n"
"  --unpack           <.deb file name> ... | -R|--recursive <бһҗбһҸ> ...\n"
"  -A|--record-avail  <.deb file name> ... | -R|--recursive <бһҗбһҸ> ...\n"
"  --configure        <package> ... | -a|--бһҖбҹҶбһ–бһ„бҹӢвҖӢбһҡбһ„бҹӢбһ…бһ¶бҹҶ\n"
"  -r|--remove        <package> ... | -a|--бһҖбҹҶбһ–бһ„бҹӢвҖӢбһҡбһ„бҹӢбһ…бһ¶бҹҶ\n"
"  -P|--purge         <package> ... | -a|--бһҖбҹҶбһ–бһ»бһ„вҖӢбһҡбһ„бҹӢбһ…бһ¶бҹҶ\n"
"  --get-selections [<pattern> ...] бһ‘бһ‘бһҪбһӣвҖӢбһ”бһ¶бһ“вҖӢбһ”бһүбҹ’бһҮбһёвҖӢбһҡбһ”бһҹбҹӢвҖӢбһҮбһҳбҹ’бһҡбһҫбһҹвҖӢбһ‘бҹ… stdoutВ бҹ”\n"
"  --set-selections                 бһҖбҹҶбһҺбһҸбҹӢвҖӢбһҮбһҳбҹ’бһҡбһҫбһҹвҖӢбһҖбһүбҹ’бһ…бһ”бҹӢвҖӢбһ–бһё stdinВ бҹ”\n"
"  --clear-selections               бһҳбһ·бһ“вҖӢбһҮбҹ’бһҡбһҫбһҹвҖӢбһӮбҹ’бһҡбһ”бҹӢвҖӢбһҖбһүбҹ’бһ…бһ”бҹӢвҖӢбһҠбҹӮбһӣвҖӢбһҳбһ·бһ“вҖӢбһҹбҹҶбһҒбһ¶бһ“бҹӢВ бҹ”\n"
"  --update-avail <Packages-file>   бһҮбҹҶбһ“бһҪбһҹвҖӢбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“вҖӢбһҖбһүбҹ’бһ…бһ”бҹӢвҖӢбһҠбҹӮбһӣвҖӢбһҳбһ¶бһ“В бҹ”\n"
"  --merge-avail <Packages-file>    бһ”бһүбҹ’бһ…бһјбһӣвҖӢвҖӢбһӮбҹ’бһ“бһ¶бһҮбһ¶вҖӢвҖӢбһҳбһҪбһҷвҖӢбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бһ–бһёвҖӢбһҜбһҖбһҹбһ¶бһҡВ бҹ”\n"
"  --clear-avail                    бһӣбһ»бһ”вҖӢбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“вҖӢбһҠбҹӮбһӣвҖӢбһўбһ¶бһ…бһ”бҹ’бһҡбһҫвҖӢбһ”бһ¶бһ“вҖӢбһҳбһ¶бһ“вҖӢбһҹбҹ’бһҡбһ¶бһ”бҹӢВ бҹ”\n"
"  --forget-old-unavail             бһ”бҹҶбһ—бҹ’бһӣбҹҒбһ…вҖӢбһҖбһүбҹ’бһ…бһ”бҹӢвҖӢбһҠбҹӮбһӣвҖӢбһҳбһ·бһ“вҖӢбһўбһ¶бһ…вҖӢбһ”бҹ’бһҡбһҫвҖӢбһ”бһ¶бһ“вҖӢбһҠбҹӮбһӣвҖӢбһҳбһ·бһ“вҖӢбһ”бһ¶бһ“вҖӢбһҠбҹҶбһЎбһҫбһ„В бҹ”\n"
"  -s|--status <package> ...        бһ”бһ„бҹ’бһ бһ¶бһүвҖӢбһҹбҹҒбһ…бһҖбҹ’бһҸбһёвҖӢбһӣбһҳбҹ’бһўбһ·бһҸвҖӢбһҹбҹ’бһҗбһ¶бһ“бһ—бһ¶бһ–вҖӢбһҖбһүбҹ’бһ…бһ”бҹӢВ бҹ”\n"
"  -p|--print-avail <package> ...   бһ”бһ„бҹ’бһ бһ¶бһүвҖӢбһҹбҹҒбһ…бһҖбҹ’бһҸбһёвҖӢбһӣбһҳбҹ’бһўбһ·бһҸвҖӢбһҖбҹҶбһҺбҹӮвҖӢбһҠбҹӮбһӣвҖӢбһҳбһ¶бһ“В бҹ”\n"
"  -L|--listfiles <package> ...     бһҡбһ¶бһҷвҖӢбһҜбһҖбһҹбһ¶бһҡ `бһҠбҹӮбһӣбһҮбһ¶вҖӢбһҳбҹ’бһ…бһ¶бһҹбҹӢ' бһҠбҹ„вҖӢбһҷбһҖбһүбҹ’бһ…бһ”бҹӢВ \n"
"  -l|--list [<pattern> ...]        бһҡбһ¶бһҷвҖӢбһҖбһүбҹ’бһ…бһ”бҹӢвҖӢбһҠбҹ„бһҷбһҹвҖӢбһ„бҹ’бһҒбҹҒбһ”В бҹ”\n"
"  -S|--search <pattern> ...        бһҡбһҖвҖӢвҖӢбһҖбһүбҹ’бһ…вҖӢбһ”бҹӢвҖӢбһҠбҹӮвҖӢбһӣвҖӢвҖӢбһҮбһ¶вҖӢбһҳбҹ’бһ…бһ¶бһҹбҹӢвҖӢбһҜбһҖбһҹбһ¶бһҡВ бҹ”\n"
"  -C|--audit                       бһ–бһ·бһ“бһ·бһҸбҹ’бһҷвҖӢбһҳбһҫбһӣвҖӢбһҖбһүбҹ’бһ…бһ”бҹӢвҖӢбһҠбҹӮбһӣвҖӢбһҒбһјбһ…В бҹ”\n"
"  --print-architecture             бһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–вҖӢбһҹбҹ’бһҗбһ¶бһ”бһҸбҹ’бһҷбһҖбһҳбҹ’бһҳвҖӢбһҡбһ”бһҹбҹӢ dpkgВ бҹ”\n"
"  --compare-versions <a> <op> <b>  бһ”бҹ’бһҡбҹҖбһ”бһ’бҹҖбһ”вҖӢбһӣбҹҒбһҒвҖӢбһҖбҹҶбһҺбҹӮ - бһҹбһјбһҳвҖӢбһҳбһҫбһӣвҖӢбһҒбһ¶бһ„вҖӢбһҖбҹ’бһҡбҹ„бһҳВ бҹ”\n"
"  --force-help                     бһ”бһ„бҹ’бһ бһ¶бһүвҖӢбһҮбҹҶбһ“бһҪбһҷвҖӢбһўбҹҶбһ–бһёвҖӢбһҖбһ¶бһҡвҖӢбһ”бһ„бҹ’бһҒбҹҶВ бҹ”\n"
"  -Dh|--debug=help                 бһ”бһ„бҹ’бһ бһ¶бһүвҖӢбһҮбҹҶбһ“бһҪбһҷвҖӢбһўбҹҶбһ–бһёвҖӢбһҖбһ¶бһҡвҖӢбһ”бҹҶбһ”бһ¶бһҸбҹӢвҖӢбһҖбҹҶбһ бһ»бһҹВ бҹ”\n"
"\n"


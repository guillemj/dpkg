#, c-format
msgid ""
"Usage: %s [<option> ...] <command>\n"
"\n"
msgstr ""
"Використання: %s [<параметр> ...] <команда>\n"
"\n"

#: src/split/main.c
#, c-format
msgid ""
"Commands:\n"
"  -s|--split <file> [<prefix>]     Split an archive.\n"
"  -j|--join <part> <part> ...      Join parts together.\n"
"  -I|--info <part> ...             Display info about a part.\n"
"  -a|--auto -o <complete> <part>   Auto-accumulate parts.\n"
"  -l|--listq                       List unmatched pieces.\n"
"  -d|--discard [<filename> ...]    Discard unmatched pieces.\n"
"\n"
msgstr ""
"Команди:\n"
"  -s|--split <файл> [<префікс>]\n"
"                           Розділити архів.\n"
"  -j|--join <частина> <частина> ...\n"
"                           Об'єднати частини.\n"
"  -I|--info <частина> ...  Показати інформацію про частину.\n"
"  -a|--auto -o <повний> <частина>\n"
"                           Автоматично збирати частини.\n"
"  -l|--listq               Вивести список невідповідних частин.\n"
"  -d|--discard [<ім'я файлу> ...]\n"
"                           Відкинути невідповідні частини.\n"
"\n"

#: src/split/main.c
#, c-format
msgid ""
"Options:\n"
"      --depotdir <directory>       Use <directory> instead of %s/%s.\n"
"      --admindir <directory>       Use <directory> instead of %s.\n"
"      --root <directory>           Use <directory> instead of %s.\n"
"  -S, --partsize <size>            In KiB, for -s (default is 450).\n"
"  -o, --output <file>              Filename, for -j (default is\n"
"                                     <package>_<version>_<arch>.deb).\n"
"  -Q, --npquiet                    Be quiet when -a is not a part.\n"
"\n"
msgstr ""
"Параметри:\n"
"  --depotdir <каталог>     Використовувати <каталог> замість %s/%s.\n"
"  --admindir <каталог>     Використовувати <каталог> замість %s.\n"
"  --root <каталог>         Використовувати <каталог> замість %s.\n"
"  -S, --partsize <розмір>  У KiB, для -s (типово 450).\n"
"  -o, --output <файл>      Ім'я файлу, для -j (типово\n"
"                           <пакунок>_<версія>_<архітектура>.deb).\n"
"  -Q, --npquiet            Не виводити повідомлення, коли -a не є частиною.\n"
"\n"


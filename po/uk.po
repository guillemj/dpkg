#, c-format
msgid ""
"Usage: %s [<option>...] <command>\n"
"\n"
msgstr ""
"Використання: %s [<параметр>...] <команда>\n"
"\n"

#: src/deb/main.c
#, c-format
msgid ""
"Commands:\n"
"  -b|--build <directory> [<deb>]   Build an archive.\n"
"  -c|--contents <deb>              List contents.\n"
"  -I|--info <deb> [<cfile>...]     Show info to stdout.\n"
"  -W|--show <deb>                  Show information on package(s)\n"
"  -f|--field <deb> [<cfield>...]   Show field(s) to stdout.\n"
"  -e|--control <deb> [<directory>] Extract metadata files.\n"
"  -x|--extract <deb> <directory>   Extract filesystem files.\n"
"  -X|--vextract <deb> <directory>  Extract and list filesystem files.\n"
"  -R|--raw-extract <deb> <directory>\n"
"                                   Extract metadata and filesystem files.\n"
"  --ctrl-tarfile <deb>             Output control tarfile.\n"
"  --fsys-tarfile <deb>             Output filesystem tarfile.\n"
"\n"
msgstr ""
"Команди:\n"
"  -b|--build <каталог> [<deb>]\n"
"                           Зібрати архів.\n"
"  -c|--contents <deb>      Вивести вміст.\n"
"  -I|--info <deb> [<cfile>...]\n"
"                           Показати інформацію на стандартному виході.\n"
"  -W|--show <deb>          Показати інформацію про пакунок(и).\n"
"  -f|--field <deb> [<cfield>...]\n"
"                           Показати поле(я) на стандартному виході.\n"
"  -e|--control <deb> [<каталог>]\n"
"                           Витягнути файли метаданих.\n"
"  -x|--extract <deb> <каталог>\n"
"                           Витягнути файли файлової системи.\n"
"  -X|--vextract <deb> <каталог>\n"
"                           Витягнути та переглянути файли файлової системи.\n"
"  -R|--raw-extract <deb> <каталог>\n"
"                           Витягнути метадані та файли файлової системи.\n"
"  --ctrl-tarfile <deb>     Вивести tar-файл control.\n"
"  --fsys-tarfile <deb>     Вивести tar-файл файлової системи.\n"
"\n"

#: src/deb/main.c src/split/main.c src/trigger/main.c src/query/main.c
#: src/main/main.c
#, c-format
msgid ""
"  -?, --help                       Show this help message.\n"
"      --version                    Show the version.\n"
"\n"
msgstr ""
"  -?, --help               Показати це довідкове повідомлення.\n"
"      --version            Показати версію.\n"
"\n"

#: src/deb/main.c
#, c-format
msgid ""
"<deb> is the filename of a Debian format archive.\n"
"<cfile> is the name of an administrative file component.\n"
"<cfield> is the name of a field in the main 'control' file.\n"
"\n"
msgstr ""
"<deb> - це ім'я файлу архіву у форматі Debian.\n"
"<cfile> - це ім'я адміністративного компонента.\n"
"<cfield> - це ім'я поля в головному файлі 'control'.\n"
"\n"

#: src/deb/main.c
#, c-format
msgid ""
"Options:\n"
"  -v, --verbose                    Enable verbose output.\n"
"  -D, --debug                      Enable debugging output.\n"
"      --showformat=<format>        Use alternative format for --show.\n"
"      --deb-format=<format>        Select archive format.\n"
"                                     Allowed values: 0.939000, 2.0 "
"(default).\n"
"      --no-check                   Suppress all checks (build bad "
"packages).\n"
"      --nocheck                    Alias for --no-check.\n"
"      --root-owner-group           Forces the owner and groups to root.\n"
"      --threads-max=<threads>      Use at most <threads> with compressor.\n"
"      --[no-]uniform-compression   Use the compression params on all "
"members.\n"
"  -Z, --compression=<compressor>   Set build compression type.\n"
"                                     Allowed types: gzip, xz, zstd, none.\n"
"  -z, --compression-level=<level>  Set build compression level.\n"
"  -S, --compression-strategy=<name>\n"
"                                   Set build compression strategy.\n"
"                                     Allowed values: none; extreme (xz);\n"
"                                     filtered, huffman, rle, fixed (gzip).\n"
"\n"
msgstr ""
"Параметри:\n"
"  -v, --verbose            Увімкнути детальний вихід.\n"
"  -D, --debug              Увімкнути вивід налагодження.\n"
"  --showformat=<формат>    Використати альтернативний формат для --show.\n"
"  --deb-format=<формат>    Вибрати формат архіву.\n"
"                                   Дозволені значення: 0.939000, 2.0 "
"(типово).\n"
"  --no-check               Придушити всі перевірки (збирати погані "
"пакунки).\n"
"  --nocheck                Псевдонім для --no-check.\n"
"  --root-owner-group       Примусово встановити власника та групу як root.\n"
"  --threads-max=<потоків>  Використовувати не більше <потоків> для "
"компресора.\n"
"  --[no-]uniform-compression\n"
"                           Використовувати параметри стиснення для\n"
"                                   всіх елементів архіву.\n"
"  -Z, --compression=<компресор>\n"
"                           Встановити тип стиснення збірки.\n"
"                           Дозволені типи: gzip, xz, zstd, none.\n"
"  -z, --compression-level=<рівень>\n"
"                           Встановити рівень стиснення збірки.\n"
"  -S, --compression-strategy=<назва>\n"
"                           Встановити стратегію стиснення збірки.\n"
"                           Допустимі значення: none; extreme (xz);\n"
"                           filtered, huffman, rle, fixed (gzip).\n"
"\n"

#: src/deb/main.c src/query/main.c
#, c-format
msgid ""
"Format syntax:\n"
"  A format is a string that will be output for each package. The format\n"
"  can include the standard escape sequences \\n (newline), \\r (carriage\n"
"  return) or \\\\ (plain backslash). Package information can be included\n"
"  by inserting variable references to package fields using the $"
"{var[;width]}\n"
"  syntax. Fields will be right-aligned unless the width is negative in "
"which\n"
"  case left alignment will be used.\n"
msgstr ""
"Синтаксис формату:\n"
"  Формат - це рядок, який буде виведено для кожного пакунка.\n"
"  Формат може містити стандартні escape-послідовності \\n (новий\n"
"  рядок), \\r (повернення каретки) або \\\\ (звичайна зворотна коса\n"
"  риска). Інформацію про пакунок можна включити шляхом вставки\n"
"  посилань на змінні до полів пакунка за допомогою синтаксису\n"
"  ${var[;width]}. Поля будуть вирівняні по правому краю, якщо ширина\n"
"  не є від'ємною, тоді буде використано вирівнювання по лівому краю.\n"

#: src/deb/main.c
#, c-format
msgid ""
"\n"
"Use 'dpkg' to install and remove packages from your system, or\n"
"'apt' or 'aptitude' for user-friendly package management. Packages\n"
"unpacked using 'dpkg-deb --extract' will be incorrectly installed !\n"
msgstr ""
"\n"
"Використовуйте 'dpkg' для встановлення та видалення пакунків\n"
"з вашої системи, або 'apt' чи 'aptitude' для зручного керування\n"
"пакунками. Пакунки, розпаковані за допомогою 'dpkg-deb --extract',\n"
"будуть встановлені неправильно!\n"

#: src/deb/main.c
msgid ""
"Type dpkg-deb --help for help about manipulating *.deb files;\n"
"Type dpkg --help for help about installing and deinstalling packages."
msgstr ""
"Введіть dpkg-deb --help для отримання допомоги щодо роботи\n"
"з файлами *.deb;\n"
"Введіть dpkg --help для отримання допомоги щодо встановлення\n"
"та видаленням пакунків."


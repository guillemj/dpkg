# EditorConfig (https://editorconfig.org/)

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true

# Makefile
[{Makefile,*.{mk,am}}]
max_line_length = 80
indent_style = tab

# Shell
[*.{sh,ac,at,m4}]
max_line_length = 80
indent_style = space
indent_size = 2
shell_variant = posix
function_next_line = true

[[shell]]
max_line_length = 80
indent_style = space
indent_size = 2
shell_variant = posix
function_next_line = true

# Perl
[*.{pl,pm,t}]
max_line_length = 80
indent_style = space
indent_size = 4

# C/C++
[*.{c,cc,h}]
max_line_length = 80
indent_style = tab
indent_size = 8
